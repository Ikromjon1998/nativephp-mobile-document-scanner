{
    "namespace": "DocumentScanner",

    "bridge_functions": [
        {
            "name": "DocumentScanner.Scan",
            "android": "com.nativephp.documentscanner.DocumentScannerFunctions.Scan",
            "ios": "DocumentScannerFunctions.Scan",
            "description": "Open the document scanner and return scanned page image paths"
        },
        {
            "name": "DocumentScanner.ImagesToPdf",
            "android": "com.nativephp.documentscanner.DocumentScannerFunctions.ImagesToPdf",
            "ios": "DocumentScannerFunctions.ImagesToPdf",
            "description": "Combine image files into a single PDF"
        },
        {
            "name": "DocumentScanner.PdfToImages",
            "android": "com.nativephp.documentscanner.DocumentScannerFunctions.PdfToImages",
            "ios": "DocumentScannerFunctions.PdfToImages",
            "description": "Extract page thumbnails from a PDF as JPEG images"
        }
    ],

    "android": {
        "min_version": 21,
        "permissions": [
            "android.permission.CAMERA"
        ],
        "dependencies": {
            "implementation": [
                "com.google.android.gms:play-services-mlkit-document-scanner:16.0.0-beta1"
            ]
        }
    },

    "ios": {
        "min_version": "13.0",
        "frameworks": [
            "VisionKit"
        ]
    },

    "events": [
        "Ikromjon\\DocumentScanner\\Events\\DocumentScanned",
        "Ikromjon\\DocumentScanner\\Events\\ScanCancelled",
        "Ikromjon\\DocumentScanner\\Events\\ScanFailed",
        "Ikromjon\\DocumentScanner\\Events\\PdfCreated"
    ]
}
