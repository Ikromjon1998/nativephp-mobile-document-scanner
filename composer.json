{
    "name": "ikromjon/nativephp-mobile-document-scanner",
    "description": "Document scanner plugin for NativePHP Mobile - scan documents with edge detection, cropping, and perspective correction using native camera APIs",
    "type": "nativephp-plugin",
    "license": "MIT",
    "keywords": [
        "nativephp",
        "mobile",
        "document-scanner",
        "scanner",
        "ocr",
        "visionkit",
        "laravel"
    ],
    "require": {
        "php": "^8.3",
        "nativephp/mobile": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.28",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Ikromjon\\DocumentScanner\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ikromjon\\DocumentScanner\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ikromjon\\DocumentScanner\\DocumentScannerServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "lint:check": "pint --test",
        "refactor": "rector process",
        "refactor:check": "rector process --dry-run",
        "check": [
            "@lint:check",
            "@refactor:check",
            "@analyse",
            "@test"
        ],
        "fix": [
            "@lint",
            "@refactor"
        ]
    }
}
